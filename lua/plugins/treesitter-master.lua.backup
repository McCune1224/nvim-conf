-- ============================================================================
-- Treesitter Configuration (main branch - 2025 rewrite)
-- ============================================================================

-- Install plugin (main branch = new rewrite API)
vim.pack.add {
  'https://github.com/nvim-treesitter/nvim-treesitter',
}

-- Setup (simplified - just sets install directory)
require('nvim-treesitter').setup {
  install_dir = vim.fn.stdpath('data') .. '/site',
}

-- Install parsers (async - will install if missing)
-- Use :wait() for synchronous install during startup if needed
require('nvim-treesitter').install({
  -- Go
  'go', 'gomod', 'gowork', 'gosum', 'gotmpl',
  -- Lua/Vim
  'lua', 'vim', 'vimdoc', 'query',
  -- Web
  'svelte', 'javascript', 'typescript', 'tsx', 'html', 'css', 'scss',
  -- Data/Config
  'json', 'jsonc', 'yaml', 'toml', 'xml',
  -- Shell
  'bash', 'fish',
  -- Documentation
  'markdown', 'markdown_inline',
  -- Other
  'regex', 'sql',
  'git_config', 'git_rebase', 'gitcommit', 'gitignore',
  'dockerfile',
  'python', 'rust',
  'c', 'cpp', 'cmake',
})

-- Enable highlighting via FileType autocmd (main branch way)
vim.api.nvim_create_autocmd('FileType', {
  pattern = {
    'go', 'gomod', 'gowork', 'gosum', 'gotmpl',
    'lua', 'vim', 'vimdoc',
    'svelte', 'javascript', 'typescript', 'tsx', 'html', 'css', 'scss',
    'json', 'jsonc', 'yaml', 'toml', 'xml',
    'bash', 'fish',
    'markdown', 'markdown_inline',
    'regex', 'sql',
    'git_config', 'git_rebase', 'gitcommit', 'gitignore',
    'dockerfile',
    'python', 'rust',
    'c', 'cpp', 'cmake',
  },
  callback = function(args)
    vim.treesitter.start(args.buf)
  end,
})

-- Treesitter-based folding (same as before)
vim.opt.foldmethod = 'expr'
vim.opt.foldexpr = 'v:lua.vim.treesitter.foldexpr()'
vim.opt.foldenable = false
vim.opt.foldlevel = 99

-- Treesitter-based indentation (main branch way)
vim.api.nvim_create_autocmd('FileType', {
  pattern = {
    'go', 'gomod', 'gowork', 'gosum', 'gotmpl',
    'lua', 'vim', 'vimdoc',
    'svelte', 'javascript', 'typescript', 'tsx', 'html', 'css', 'scss',
    'json', 'jsonc', 'yaml', 'toml', 'xml',
    'bash', 'fish',
    'python', 'rust',
    'c', 'cpp', 'cmake',
  },
  callback = function()
    vim.bo.indentexpr = "v:lua.require'nvim-treesitter'.indentexpr()"
  end,
})
